<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.antivirus.ui.ChangePasswordController"
      spacing="20"
      styleClass="change-password-container"
      alignment="CENTER">

    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <!-- Header -->
    <VBox spacing="8" alignment="CENTER">
        <Label text="🔐" styleClass="change-password-icon"/>
        <Label text="Changer le mot de passe" styleClass="change-password-title"/>
        <Label text="Sécurisez votre compte SeekMal" styleClass="change-password-subtitle"/>
    </VBox>

    <!-- Form -->
    <VBox spacing="15" styleClass="change-password-form">
        <VBox spacing="6">
            <Label text="Ancien mot de passe" styleClass="change-password-label"/>
            <PasswordField fx:id="oldPasswordField" 
                          promptText="Entrez votre mot de passe actuel"
                          styleClass="change-password-field"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Nouveau mot de passe" styleClass="change-password-label"/>
            <PasswordField fx:id="newPasswordField" 
                          promptText="Minimum 6 caractères"
                          styleClass="change-password-field"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Confirmer le mot de passe" styleClass="change-password-label"/>
            <PasswordField fx:id="confirmPasswordField" 
                          promptText="Confirmez votre nouveau mot de passe"
                          styleClass="change-password-field"/>
        </VBox>

        <Label fx:id="errorLabel" text="" styleClass="change-password-error" visible="false" wrapText="true"/>
    </VBox>

    <!-- Buttons -->
    <HBox spacing="12" alignment="CENTER">
        <Button fx:id="changeButton" text="Changer le mot de passe" onAction="#handleChangePassword" 
                prefWidth="180" prefHeight="40" styleClass="change-password-primary-button"/>
        <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancel" 
                prefWidth="120" prefHeight="40" styleClass="change-password-secondary-button"/>
    </HBox>

    <!-- Security tip -->
    <Label text="💡 Astuce : Utilisez un mot de passe complexe avec lettres, chiffres et symboles" 
           styleClass="change-password-tip" wrapText="true"/>
</VBox>
